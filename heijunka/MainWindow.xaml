<Window x:Class="heijunka.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:heijunka.Views"
        Title="Heijunka Scheduler"
        Height="800" Width="1200"
        MinHeight="600" MinWidth="900">

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<!-- 메인 탭 -->
		<TabControl Grid.Row="0" x:Name="MainTab" Margin="8">

			<TabItem Header="⚙ 기본설정">
				<views:SettingsView x:Name="SettingsView"/>
			</TabItem>

			<TabItem Header="📐 타임펜스">
				<views:TimeFenceView x:Name="TimeFenceView"/>
			</TabItem>

			<TabItem Header="🔀 시퀀싱">
				<views:SequencingView x:Name="SequencingView"/>
			</TabItem>

		</TabControl>

		<!-- 상태바 -->
		<StatusBar Grid.Row="1">
			<StatusBarItem>
				<TextBlock x:Name="TxtStatusBar" Text="준비"/>
			</StatusBarItem>
		</StatusBar>

	</Grid>
</Window>