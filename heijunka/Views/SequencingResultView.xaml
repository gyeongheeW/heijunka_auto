<UserControl x:Class="heijunka.Views.SequencingResultView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 펜스별 오더수 및 품질점수 테이블 -->
        <GroupBox Grid.Row="0" Header="펜스별 오더수 및 품질점수">
            <DataGrid x:Name="DgSequencingResult"
                      AutoGenerateColumns="True"
                      IsReadOnly="True"
                      AlternatingRowBackground="#F8F9FA"
                      GridLinesVisibility="All"/>
        </GroupBox>

        <!-- 버튼 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal"
                    Margin="0,8,0,0">
            <Button x:Name="BtnSave" Content="💾 저장"
                    Padding="16,8" Margin="0,0,8,0"
                    Background="#4ECDC4" Foreground="White"
                    FontWeight="Bold"
                    IsEnabled="False"
                    Click="BtnSave_Click"/>
            <Button x:Name="BtnRerun" Content="🔄 재실행"
                    Padding="16,8" Margin="0,0,8,0"
                    IsEnabled="False"
                    Click="BtnRerun_Click"/>
            <Button x:Name="BtnCancel" Content="✕ 취소"
                    Padding="16,8"
                    IsEnabled="False"
                    Click="BtnCancel_Click"/>
        </StackPanel>

    </Grid>
</UserControl>