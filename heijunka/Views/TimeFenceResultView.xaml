<UserControl x:Class="heijunka.Views.TimeFenceResultView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 펜스별 수량 테이블 -->
        <GroupBox Grid.Row="0" Header="펜스별 수량">
            <DataGrid x:Name="DgPlanResult"
                      AutoGenerateColumns="True"
                      IsReadOnly="True"
                      AlternatingRowBackground="#F8F9FA"
                      GridLinesVisibility="All"/>
        </GroupBox>

        <!-- 시프트별 예상 종료시간 -->
        <GroupBox Grid.Row="1" Header="시프트별 예상 종료시간"
                  Margin="0,8,0,8">
            <StackPanel x:Name="PanelShiftTimes" Margin="8">
                <TextBlock Text="실행 후 표시됩니다."
                           Foreground="#64748B"/>
            </StackPanel>
        </GroupBox>

        <!-- 버튼 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal">
            <Button x:Name="BtnSave" Content="💾 저장"
                    Padding="16,8" Margin="0,0,8,0"
                    Background="#4ECDC4" Foreground="White"
                    FontWeight="Bold"
                    IsEnabled="False"
                    Click="BtnSave_Click"/>
            <Button x:Name="BtnRerun" Content="🔄 재실행"
                    Padding="16,8" Margin="0,0,8,0"
                    IsEnabled="False"
                    Click="BtnRerun_Click"/>
            <Button x:Name="BtnCancel" Content="✕ 취소"
                    Padding="16,8"
                    IsEnabled="False"
                    Click="BtnCancel_Click"/>
        </StackPanel>

    </Grid>
</UserControl>