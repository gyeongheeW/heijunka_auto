<UserControl x:Class="heijunka.Views.QualityView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 전체 품질점수 요약 -->
        <GroupBox Grid.Row="0" Header="전체 품질점수 요약"
                  Margin="0,0,0,8">
            <StackPanel x:Name="PanelSummary" Margin="8"
                        Orientation="Horizontal">
                <TextBlock Text="실행 후 표시됩니다."
                           Foreground="#64748B"/>
            </StackPanel>
        </GroupBox>

        <!-- 버킷별 분류 점수 테이블 -->
        <GroupBox Grid.Row="1" Header="버킷별 분류 점수">
            <DataGrid x:Name="DgQuality"
                      AutoGenerateColumns="True"
                      IsReadOnly="True"
                      AlternatingRowBackground="#F8F9FA"
                      GridLinesVisibility="All"/>
        </GroupBox>

        <!-- 판정 -->
        <GroupBox Grid.Row="2" Header="판정" Margin="0,8,0,0">
            <StackPanel x:Name="PanelJudge" Margin="8">
                <TextBlock Text="실행 후 표시됩니다."
                           Foreground="#64748B"/>
            </StackPanel>
        </GroupBox>

    </Grid>
</UserControl>