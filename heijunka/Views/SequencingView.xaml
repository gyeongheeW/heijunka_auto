<UserControl x:Class="heijunka.Views.SequencingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:heijunka.Views">

    <TabControl x:Name="SequencingSubTab">

        <TabItem Header="📂 파일">
            <views:SequencingFileView x:Name="FileView"/>
        </TabItem>

        <TabItem Header="📊 결과">
            <views:SequencingResultView x:Name="ResultView"/>
        </TabItem>

        <TabItem Header="⭐ 품질점수">
            <views:QualityView x:Name="QualityView"/>
        </TabItem>

        <TabItem Header="📋 로그">
            <views:SequencingLogView x:Name="LogView"/>
        </TabItem>

    </TabControl>
</UserControl>