<UserControl x:Class="heijunka.Views.TimeFenceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:heijunka.Views">

    <TabControl x:Name="TimeFenceSubTab">

        <TabItem Header="📂 파일">
            <views:TimeFenceFileView x:Name="FileView"/>
        </TabItem>

        <TabItem Header="📋 결과 (생산)">
            <views:TimeFenceResultView x:Name="ResultView"/>
        </TabItem>

        <TabItem Header="📦 결과 (기말재고)">
            <views:TimeFenceEndingView x:Name="EndingView"/>
        </TabItem>

        <TabItem Header="📝 로그">
            <views:TimeFenceLogView x:Name="LogView"/>
        </TabItem>

    </TabControl>
</UserControl>