<UserControl x:Class="heijunka.Views.TransferTableView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 파일 선택 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="파일" VerticalAlignment="Center" Width="40"/>
            <TextBox x:Name="TxtTransferPath" Width="400"
                     IsReadOnly="True" Margin="0,0,4,0"
                     VerticalAlignment="Center"/>
            <Button Content="찾아보기" Padding="8,4"
                    Margin="0,0,4,0"
                    Click="BtnBrowse_Click"/>
            <Button Content="로드" Padding="8,4"
                    Background="#4ECDC4" Foreground="White"
                    Click="BtnLoad_Click"/>
        </StackPanel>

        <!-- 전환테이블 -->
        <DataGrid Grid.Row="1" x:Name="DgTransfer"
                  AutoGenerateColumns="True"
                  IsReadOnly="True"
                  AlternatingRowBackground="#F8F9FA"
                  GridLinesVisibility="All"/>
    </Grid>
</UserControl>