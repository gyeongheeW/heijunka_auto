<UserControl x:Class="heijunka.Views.MasterDataView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 파일 선택 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="파일" VerticalAlignment="Center" Width="40"/>
            <TextBox x:Name="TxtMasterPath" Width="400"
                     IsReadOnly="True" Margin="0,0,4,0"
                     VerticalAlignment="Center"/>
            <Button Content="찾아보기" Padding="8,4"
                    Margin="0,0,4,0"
                    Click="BtnBrowse_Click"/>
            <Button Content="로드" Padding="8,4"
                    Background="#4ECDC4" Foreground="White"
                    Click="BtnLoad_Click"/>
        </StackPanel>

        <!-- 시프트 시작시간 -->
        <GroupBox Grid.Row="1" Header="시프트 시작시간" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal" Margin="8">

                <TextBlock Text="시프트1" VerticalAlignment="Center"
                           Margin="0,0,4,0"/>
                <TextBox x:Name="TxtShift1Start" Width="60" Text="08:00"
                         VerticalAlignment="Center" Margin="0,0,16,0"/>

                <TextBlock Text="시프트2" VerticalAlignment="Center"
                           Margin="0,0,4,0"/>
                <TextBox x:Name="TxtShift2Start" Width="60" Text="16:00"
                         VerticalAlignment="Center" Margin="0,0,16,0"/>

                <TextBlock Text="시프트3" VerticalAlignment="Center"
                           Margin="0,0,4,0"/>
                <TextBox x:Name="TxtShift3Start" Width="60" Text="00:00"
                         VerticalAlignment="Center"/>

            </StackPanel>
        </GroupBox>

        <!-- 품목 테이블 -->
        <DataGrid Grid.Row="2" x:Name="DgMaster"
                  AutoGenerateColumns="True"
                  IsReadOnly="True"
                  AlternatingRowBackground="#F8F9FA"
                  GridLinesVisibility="All"/>
    </Grid>
</UserControl>