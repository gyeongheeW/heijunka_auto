<UserControl x:Class="heijunka.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:heijunka.Views">

    <TabControl>

        <TabItem Header="⚙ 설정값">
            <views:SettingsValueView x:Name="SettingsValue"/>
        </TabItem>

        <TabItem Header="📋 기준정보">
            <views:MasterDataView x:Name="MasterData"/>
        </TabItem>

        <TabItem Header="🔀 전환테이블">
            <views:TransferTableView x:Name="TransferTable"/>
        </TabItem>

        <TabItem Header="🏷 분류설정">
            <views:ClassSettingsView x:Name="ClassSettings"/>
        </TabItem>

    </TabControl>
</UserControl>